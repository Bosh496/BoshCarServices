@if (IsVisible)
{
    <div class="loader-overlay">
        <div class="loader-container">
            <div class="premium-loader"></div>
            <div class="loader-text">Processing...</div>
        </div>
    </div>
}

<style>
    .loader-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(15, 23, 42, 0.45);
        backdrop-filter: blur(12px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        animation: fadeIn 0.3s ease-in-out;
    }

    .loader-container {
        text-align: center;
    }

    .premium-loader {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        position: relative;
        background: conic-gradient( from 0deg, #1976d2, #42a5f5, #c62828, #1976d2 );
        animation: spin 1.2s linear infinite;
        box-shadow: 0 0 25px rgba(25, 118, 210, 0.6), 0 0 50px rgba(198, 40, 40, 0.4);
    }

        .premium-loader::before {
            content: "";
            position: absolute;
            inset: 8px;
            background: rgba(255, 255, 255, 0.95);
            border-radius: 50%;
            backdrop-filter: blur(10px);
        }

    .loader-text {
        margin-top: 16px;
        font-weight: 600;
        font-size: 14px;
        color: #e3f2fd;
        letter-spacing: 0.5px;
        animation: pulse 1.5s infinite;
    }

    @@keyframes spin {
        100% {
            transform: rotate(360deg);
        }
    }

    @@keyframes pulse {
        0%, 100% {
            opacity: 0.6;
        }

        50% {
            opacity: 1;
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
}