@page "/"
@inject NavigationManager Navigation

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter', sans-serif;
        overflow-x: hidden;
        background: #e3f2fd;
    }

    /* premium light blue gradient background with subtle depth */
    .hero-premium {
        position: relative;
        min-height: 100vh;
        width: 100%;
        background: linear-gradient(135deg, #e3f2fd 0%, #bbdef5 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    /* subtle light blue glowing orbs */
    .orb-1, .orb-2, .orb-3 {
        position: absolute;
        border-radius: 50%;
        filter: blur(100px);
        opacity: 0.3;
        z-index: 0;
        animation: floatOrb 18s infinite alternate ease-in-out;
    }

    .orb-1 {
        width: 50vw;
        height: 50vw;
        background: radial-gradient(circle, #90caf9, #64b5f6);
        top: -15%;
        left: -10%;
        opacity: 0.25;
    }

    .orb-2 {
        width: 40vw;
        height: 40vw;
        background: radial-gradient(circle, #81d4fa, #4fc3f7);
        bottom: -10%;
        right: -5%;
        opacity: 0.25;
        animation-duration: 24s;
    }

    .orb-3 {
        width: 35vw;
        height: 35vw;
        background: radial-gradient(circle, #b3e5fc, #81d4fa);
        top: 40%;
        left: 60%;
        opacity: 0.2;
        animation-duration: 20s;
        filter: blur(120px);
    }

    @@keyframes floatOrb {
        0% {
            transform: translate(0, 0) scale(1);
        }

        100% {
            transform: translate(5%, 8%) scale(1.1);
        }
    }

    /* main glass-card container - light blue version */
    .glass-card {
        position: relative;
        z-index: 20;
        width: 90%;
        max-width: 1300px;
        margin: 2rem;
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(16px);
        border-radius: 2rem;
        border: 1px solid rgba(255, 255, 255, 0.9);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08), inset 0 1px 0 rgba(255,255,255,0.9);
        padding: 2rem;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
    }

        .glass-card::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(115deg, rgba(255,255,255,0) 30%, rgba(255,255,255,0.4) 50%, rgba(255,255,255,0) 70%);
            transform: rotate(25deg);
            animation: shimmer 8s infinite;
            pointer-events: none;
        }

    @@keyframes shimmer {
        0% {
            transform: translateX(-100%) rotate(25deg);
        }

        20% {
            transform: translateX(100%) rotate(25deg);
        }

        100% {
            transform: translateX(200%) rotate(25deg);
        }
    }

    /* layout: flex for image + text */
    .premium-layout {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
    }

    .content-left {
        flex: 1.2;
        min-width: 260px;
        padding: 1rem;
    }

    .visual-right {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
    }

    /* badge / brand - dark text version */
    .brand-badge {
        display: inline-block;
        background: rgba(25, 118, 210, 0.1);
        backdrop-filter: blur(4px);
        border-left: 4px solid #1976d2;
        padding: 0.4rem 1.2rem;
        border-radius: 40px;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 1px;
        color: #0d47a1;
        margin-bottom: 1.5rem;
        text-transform: uppercase;
    }

    h1 {
        font-size: 3.8rem;
        font-weight: 800;
        background: linear-gradient(135deg, #0d47a1 30%, #1976d2 70%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        letter-spacing: -0.02em;
        margin-bottom: 0.5rem;
        font-family: 'Playfair Display', serif;
    }

    .subhead {
        font-size: 1.8rem;
        font-weight: 700;
        color: #0d47a1;
        margin-bottom: 0.75rem;
        letter-spacing: -0.3px;
    }

    .highlight-red {
        color: #c62828;
        font-weight: 800;
    }

    .tagline-premium {
        font-size: 1.2rem;
        font-weight: 600;
        color: #1565c0;
        margin-top: 0.5rem;
        border-left: 3px solid #c62828;
        padding-left: 1rem;
    }

    .desc-text {
        margin-top: 1.8rem;
        color: #1a237e;
        line-height: 1.6;
        font-size: 1rem;
        max-width: 90%;
        font-weight: 500;
    }

    .feature-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 1.2rem;
        margin: 2rem 0 1.5rem;
    }

    .feature-item {
        display: flex;
        align-items: center;
        gap: 10px;
        background: rgba(25, 118, 210, 0.08);
        padding: 0.5rem 1rem;
        border-radius: 50px;
        backdrop-filter: blur(4px);
        font-size: 0.85rem;
        font-weight: 600;
        color: #0d47a1;
        transition: all 0.3s ease;
    }

        .feature-item:hover {
            background: rgba(198, 40, 40, 0.1);
            transform: translateX(5px);
        }

        .feature-item i {
            color: #c62828;
            font-size: 1rem;
        }

    .address-premium {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(25, 118, 210, 0.08);
        padding: 0.7rem 1.3rem;
        border-radius: 40px;
        margin-top: 0.8rem;
        font-size: 0.9rem;
        color: #0d47a1;
        border: 1px solid rgba(198, 40, 40, 0.2);
        font-weight: 500;
    }

        .address-premium i {
            color: #c62828;
        }

    /* Premium CTA button (admin) */
    .admin-btn {
        margin-top: 2.2rem;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        background: linear-gradient(105deg, #c62828 0%, #1565c0 100%);
        border: none;
        padding: 1rem 2.2rem;
        border-radius: 60px;
        font-weight: 700;
        font-size: 1.1rem;
        color: white;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 8px 20px rgba(198, 40, 40, 0.25);
        letter-spacing: 1px;
        backdrop-filter: blur(4px);
        z-index: 25;
    }

        .admin-btn i {
            font-size: 1.2rem;
            transition: transform 0.2s;
        }

        .admin-btn:hover {
            transform: translateY(-5px);
            background: linear-gradient(105deg, #e53935, #1976d2);
            box-shadow: 0 15px 30px rgba(198, 40, 40, 0.35);
        }

            .admin-btn:hover i {
                transform: translateX(5px);
            }

    /* Real Car Image Styling */
    .car-image-container {
        position: relative;
        width: 100%;
        max-width: 550px;
        margin: 0 auto;
        perspective: 1000px;
    }

    .real-car-image {
        width: 100%;
        height: auto;
        border-radius: 20px;
        filter: drop-shadow(0 15px 25px rgba(0,0,0,0.12)) drop-shadow(0 0 10px rgba(25,118,210,0.2));
        transition: all 0.4s ease;
        animation: floatCar 4s infinite alternate ease-in-out;
    }

        .real-car-image:hover {
            transform: scale(1.02);
            filter: drop-shadow(0 20px 35px rgba(0,0,0,0.15)) drop-shadow(0 0 15px rgba(25,118,210,0.3));
        }

    .car-glow-ring {
        position: absolute;
        bottom: -5%;
        left: 10%;
        width: 80%;
        height: 25px;
        background: radial-gradient(ellipse, rgba(25,118,210,0.25), transparent);
        filter: blur(15px);
        border-radius: 50%;
        z-index: -1;
        animation: pulseGlow 3s infinite alternate;
    }

    @@keyframes pulseGlow {
        0% {
            opacity: 0.3;
            transform: scale(0.95);
        }

        100% {
            opacity: 0.6;
            transform: scale(1.05);
        }
    }

    @@keyframes floatCar {
        0% {
            transform: translateY(0px);
        }

        100% {
            transform: translateY(-8px);
        }
    }

    /* stats row - dark text */
    .stats-row {
        display: flex;
        gap: 2rem;
        margin-top: 2rem;
        flex-wrap: wrap;
    }

    .stat {
        display: flex;
        flex-direction: column;
    }

    .stat-number {
        font-size: 1.8rem;
        font-weight: 800;
        color: #c62828;
        line-height: 1;
    }

    .stat-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #0d47a1;
        font-weight: 700;
    }

    /* Rating badge */
    .rating-badge {
        position: absolute;
        top: 5%;
        right: 5%;
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(12px);
        padding: 0.5rem 1.2rem;
        border-radius: 50px;
        font-size: 0.9rem;
        font-weight: bold;
        color: #c62828;
        border: 1px solid rgba(25, 118, 210, 0.2);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
        font-family: 'Inter', sans-serif;
    }

        .rating-badge i {
            color: #f39c12;
            margin-right: 2px;
        }

    /* Responsive */
    @@media (max-width: 900px) {
        .premium-layout {
            flex-direction: column;
        }

        h1 {
            font-size: 2.5rem;
        }

        .subhead {
            font-size: 1.3rem;
        }

        .glass-card {
            padding: 1.5rem;
        }

        .admin-btn {
            padding: 0.8rem 1.8rem;
        }

        .car-image-container {
            max-width: 100%;
        }
    }

    @@media (max-width: 550px) {
        .feature-grid {
            gap: 0.8rem;
        }

        .desc-text {
            max-width: 100%;
        }

        .rating-badge {
            font-size: 0.7rem;
            padding: 0.3rem 0.8rem;
        }
    }
</style>

<div class="hero-premium">
    <div class="orb-1"></div>
    <div class="orb-2"></div>
    <div class="orb-3"></div>

    <div class="glass-card">
        <div class="premium-layout">
            <!-- Left side: text content -->
            <div class="content-left">
                <div class="brand-badge">
                    <i class="fas fa-certificate"></i> OFFICIAL PARTNER
                </div>
                <h1>Bosch Car Service</h1>
                <div class="subhead">
                    <span class="highlight-red">Auto Xpertz</span>
                </div>
                <div class="tagline-premium">
                    Trusted Car Workshop For Repair & Services
                </div>
                <p class="desc-text">
                    Premium vehicle care with expert technicians. Fast, reliable, and high-quality service
                    for all car brands — from luxury sedans to powerful SUVs. State-of-the-art diagnostic
                    tools and genuine parts ensure your drive stays perfect.
                </p>

                <div class="feature-grid">
                    <div class="feature-item"><i class="fas fa-wrench"></i> Expert Diagnostics</div>
                    <div class="feature-item"><i class="fas fa-bolt"></i> 24/7 Roadside Assist</div>
                    <div class="feature-item"><i class="fas fa-tachometer-alt"></i> Performance Tuning</div>
                    <div class="feature-item"><i class="fas fa-shield-alt"></i> Warranty on Parts</div>
                </div>

                <div class="address-premium">
                    <i class="fas fa-map-marker-alt"></i> Chitradurga, Karnataka | <i class="fas fa-phone-alt"></i> +91 98450 12345
                </div>

                <!-- Stats -->
                <div class="stats-row">
                    <div class="stat"><span class="stat-number">15+</span><span class="stat-label">YEARS EXP</span></div>
                    <div class="stat"><span class="stat-number">8k+</span><span class="stat-label">CARS SERVICED</span></div>
                    <div class="stat"><span class="stat-number">100%</span><span class="stat-label">CUSTOMER TRUST</span></div>
                </div>

                <!-- Admin CTA -->
                <button class="admin-btn" @onclick="GoToLogin">
                    <i class="fas fa-user-shield"></i> Admin Portal
                    <i class="fas fa-arrow-right"></i>
                </button>
            </div>

            <!-- Right side: Real Premium Car Image -->
            <div class="visual-right">
                <div class="car-image-container">
                    <img class="real-car-image"
                         src="https://images.unsplash.com/photo-1555215695-3004980ad54e?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80"
                         alt="Premium Luxury Car - Bosch Service" />
                    <div class="car-glow-ring"></div>
                    <!-- Rating badge -->
                    <div class="rating-badge">
                        <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i> 4.9 ★ TrustScore
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }
}