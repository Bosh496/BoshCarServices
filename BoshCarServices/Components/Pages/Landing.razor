@page "/"
@inject NavigationManager nav
<style>
    .premium-container {
        height: 100vh;
        background: radial-gradient(circle at center, #fff, #2a5298);
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden;
    }

        /* GLOW EFFECT BACKGROUND */
        .premium-container::before {
            content: "";
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(255,0,0,0.2), transparent);
            filter: blur(120px);
        }

    /* CONTENT */
    .content {
        text-align: center;
        color: white;
        z-index: 2;
    }

    h1 {
        font-size: 36px;
        font-weight: bold;
        letter-spacing: 2px;
    }

    h2 {
        font-size: 24px;
        color: #ff2e2e;
        margin-bottom: 10px;
    }

    .tagline {
        color: #000000;
        font-size: 16px;
    }

    .desc {
        margin-top: 10px;
        color: #000000;
        font-size: 14px;
    }

    .address {
        margin-top: 10px;
        font-size: 13px;
        color: #000000;
    }

    /* 🔥 ENGINE BUTTON (LIKE IMAGE) */
    .start-btn {
        margin: 40px auto;
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background: radial-gradient(circle, #ff2e2e, #990000);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
        letter-spacing: 1px;
        cursor: pointer;
        box-shadow: 0 0 20px #ff2e2e, 0 0 40px rgba(255, 0, 0, 0.6), inset 0 0 20px rgba(0,0,0,0.6);
        transition: 0.3s;
    }

        /* HOVER EFFECT */
        .start-btn:hover {
            transform: scale(1.1);
            box-shadow: 0 0 40px #ff2e2e, 0 0 80px rgba(255, 0, 0, 1), inset 0 0 30px rgba(0,0,0,0.8);
        }
</style>
<div class="premium-container">

    <div class="content">

        <h1>Bosch Car Service</h1>
        <h2>Auto Xpertz</h2>

        <p class="tagline">
            Trusted Car Workshop For Repair & Services
        </p>

        <p class="desc">
            Premium vehicle care with expert technicians.
            Fast, reliable, and high-quality service for all car brands.
        </p>

        <p class="address">
            📍 Chitradurga, Karnataka
        </p>

        <div class="start-btn" @onclick="GoToLogin">
            Admin
        </div>

    </div>

</div>

@code {
    void GoToLogin()
    {
        nav.NavigateTo("/login");
    }
}